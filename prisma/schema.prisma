
generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Better Auth required models ---

model Role {
  id    String @id @default(cuid())
  name  String @unique

  users User[]

  @@map("roles")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?

  // Champ string conservé pour Better Auth (additionalFields + session)
  role   String @default("USER")
  roleId String? @map("role_id")
  roleRef Role?  @relation(fields: [roleId], references: [id])

  // Audit trail — qui a modifié le rôle et quand
  roleChangedAt DateTime? @map("role_changed_at")
  roleChangedBy String?   @map("role_changed_by")

  // Bannissement sans suppression du compte
  bannedAt  DateTime? @map("banned_at")
  banReason String?   @map("ban_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts    Account[]
  sessions    Session[]
  challenges  Challenge[]
  sensitivity Sensitivity?

  @@index([role])
  @@index([roleId])
  @@map("users")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  idToken               String?   @map("id_token") @db.Text
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("verifications")
  @@index([identifier])
}

// --- App models ---

enum Plateforme {
  MANETTE
  CLAVIER_SOURIS
}

enum TypeEntrainement {
  STRAFE
  TARGET_SWITCHING
  TRACKING
  FLICKING
  MICRO_AJUSTEMENT
  CLOSE_RANGE
  LONGUE_DISTANCE
  LIBRE
}

model Challenge {
  id            String   @id @default(cuid())
  challengeName String   @map("challenge_name")
  shotsHit      Int      @map("shots_hit")
  kills         Int
  weapon        String
  accuracy      Float
  damage        Int
  criticalShots Int      @map("critical_shots")
  totalShots    Int      @map("total_shots")
  roundtime     Int
  createdAt     DateTime @default(now()) @map("created_at")

  plateforme       Plateforme?       @map("plateforme")
  typeEntrainement TypeEntrainement? @map("type_entrainement")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([weapon])
  @@index([challengeName])
  @@index([userId])
  @@index([plateforme])
  @@index([typeEntrainement])
  @@map("challenges")
}

model Sensitivity {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // --- Souris ---
  mouseDpi         Int   @default(800) @map("mouse_dpi")
  mouseSensitivity Float @default(1.0) @map("mouse_sensitivity")

  // Multiplicateurs optiques souris — stockés en JSON
  // { x1, x2, x3, x4, x6, x8, x10 } tous à 1.0 par défaut
  mouseOpticEnabled  Boolean @default(false) @map("mouse_optic_enabled")
  mouseOpticSettings Json    @default("{}") @map("mouse_optic_settings")

  // --- Manette ---
  baseControllerSetting String @default("4-4 Classic") @map("base_controller_setting")

  // {responseCurve, deadzone, outerThreshold}
  advancedControllerSettingEnable Boolean @default(false) @map("advance_controller_setting_enable")
  advancedControllerSettings      Json    @default("{}") @map("advance_controller_setting")

  // Multiplicateurs optiques manette — même structure JSON que souris
  controllerOpticEnabled  Boolean @default(false) @map("controller_optic_enabled")
  controllerOpticSettings Json    @default("{}") @map("controller_optic_settings")

  // Paramètres de rotation — stockés en JSON pour éviter 12 colonnes
  // { yaw, pitch, turningExtraYaw, turningExtraPitch, turningRampUpTime, turningRampUpDelay }
  hipfireSettings Json @default("{}") @map("hipfire_settings")

  // Mêmes champs mais en ADS
  // { yaw, pitch, turningExtraYaw, turningExtraPitch, turningRampUpTime, turningRampUpDelay }
  adsSettings Json @default("{}") @map("ads_settings")

  @@map("sensitivities")
}
